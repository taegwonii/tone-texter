{
  "manifest_version": 3,
  "name": "ToneTexter — Natural Texting Assistant",
  "version": "1.0.0",
  "description": "Sound more natural when texting in English. Tone-based suggestions: casual, friendly, polite, Gen Z.",
  "permissions": ["storage"],
  "host_permissions": ["https://api.anthropic.com/*"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ToneTexter Settings"
  }
}
